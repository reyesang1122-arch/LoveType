# Public site URL (used for SEO, OG tags, share links)
NEXT_PUBLIC_SITE_URL=https://lovetype.smartflowaimalaysia.com

# Xinyu (心语) conversion destination
NEXT_PUBLIC_XINYU_URL=https://love.smartflowaimalaysia.com

# Supabase — required for analytics + the /feedback dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (server-only) — used by /feedback to read aggregates.
# NEVER expose this to the client. Keep it out of NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# Password gate for the /feedback analytics dashboard
FEEDBACK_PASSWORD=
